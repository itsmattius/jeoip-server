APP_NAME=Lumen
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_SLACK_WEBHOOK_URL=

# MaxMind GeoLite2 MMDB file paths.
# Defaults: storage/geoip/GeoLite2-{City,Country,ASN}.mmdb
GEOIP_CITY_DB=
GEOIP_COUNTRY_DB=
GEOIP_ASN_DB=

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
