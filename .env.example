APP_NAME=Lumen
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_SLACK_WEBHOOK_URL=

# MaxMind GeoLite2 MMDB file paths.
# Defaults: storage/geoip/GeoLite2-{City,Country,ASN}.mmdb
GEOIP_CITY_DB=
GEOIP_COUNTRY_DB=
GEOIP_ASN_DB=

# Trusted proxies for resolving the real client IP behind a CDN/load balancer.
# Comma-separated list of IPs or CIDR ranges, or "*" to trust whichever proxy
# is connected (only safe if the origin is reachable ONLY via the CDN).
# Example for Cloudflare: paste from https://www.cloudflare.com/ips-v4 (and v6)
# TRUSTED_PROXIES=173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,...
TRUSTED_PROXIES=

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
